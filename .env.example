# ============================================================
# Office LLM Harness — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.
# All values have sensible defaults if not set.

# MCP Server (runs locally on user's PC)
MCP_HOST=127.0.0.1       # Bind address (localhost only by default)
MCP_PORT=3000            # HTTP port for MCP server

# Static File Server (Helm deployment — no env vars needed)
# Serves add-in UI files via nginx in Kubernetes
